# ═══════════════════════════════════════════════════════════════
# Environment Configuration Template
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your actual values

# Application Settings
APP_NAME=agentic-ai-platform
APP_VERSION=1.0.0
ENVIRONMENT=development  # development, staging, production
DEBUG=false

# LLM Configuration (Qwen via vLLM - OpenAI-compatible API)
LLM_PROVIDER=openai_compatible  # vLLM serving Qwen
LLM_BASE_URL=http://localhost:8000/v1
LLM_MODEL=Qwen3-30B-A3B
LLM_API_KEY=abc-123
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2000
LLM_TIMEOUT=30

# OpenAI client compatibility (for pydantic-ai and other tools)
BASE_URL=http://localhost:8000/v1
OPENAI_API_KEY=abc-123

# Legacy (kept for reference)
# MISTRAL_API_KEY=your-mistral-api-key-here

# MCP Server Configuration
MCP_TELEMETRY_HOST=localhost
MCP_TELEMETRY_PORT=8001
MCP_SSH_HOST=localhost
MCP_SSH_PORT=8002
MCP_CMDB_HOST=localhost
MCP_CMDB_PORT=8003
MCP_ALERTING_HOST=localhost
MCP_ALERTING_PORT=8004
MCP_RUNBOOK_HOST=localhost
MCP_RUNBOOK_PORT=8005

# Vector Database Configuration
VECTOR_DB_PROVIDER=mock  # mock, pinecone, weaviate, chromadb
VECTOR_DB_ENDPOINT=
VECTOR_DB_API_KEY=
VECTOR_DB_INDEX=incidents
EMBEDDING_MODEL=all-MiniLM-L6-v2
SIMILARITY_THRESHOLD=0.7

# Agent Configuration
DIAGNOSIS_THRESHOLD=0.80
GATHERING_THRESHOLD=0.85
MAX_GATHERING_ITERATIONS=10
APPROVAL_REQUIRED_TIERS=critical,high

# Logging Configuration
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FILE=logs/agentic-ai.log
ENABLE_FILE_LOGGING=false
LOG_MAX_BYTES=10485760  # 10MB
LOG_BACKUP_COUNT=5

# Database Configuration (for future use)
DATABASE_URL=postgresql://user:password@localhost:5432/agentic_ai
DATABASE_POOL_SIZE=5
DATABASE_ECHO=false

# External Services
PROMETHEUS_URL=http://localhost:9090
SLACK_WEBHOOK_URL=
PAGERDUTY_API_KEY=
DATADOG_API_KEY=

# Security
API_KEY_SECRET=your-secret-key-here
JWT_SECRET=your-jwt-secret-here
